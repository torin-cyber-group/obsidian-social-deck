        "jsCode": "function unwrap(value) {\n  if (Array.isArray(value)) {\n    return unwrap(value[0]);\n  }\n  if (value && typeof value === 'object') {\n    return value.json ?? value.data ?? value.result ?? value;\n  }\n  return value;\n}\n\nconst previous = $('If Bluesky enabled').first().json;\nconst result = unwrap($json);\nreturn [{ json: {\n  ...previous,\n  results: [...(previous.results ?? []), result]\n} }];"
