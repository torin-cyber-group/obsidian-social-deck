    {
      "parameters": {
        "jsCode": "const body = $json.body ?? {};\nconst platforms = body.platforms ?? {};\nconst enabled = {};\n\nif (body.schemaVersion !== 1) {\n  throw new Error('Unsupported Social Deck schema version');\n}\n\nif (body.testConnection === true) {\n  return [{ json: {\n    route: 'connection-test',\n    response: {\n      ok: true,\n      type: 'connection-test',\n      source: 'n8n',\n      receivedAt: new Date().toISOString()\n    }\n  } }];\n}\n\nfunction parseText(platform, limit) {\n  const value = platforms[platform]?.text;\n  if (value === undefined || value === null) {\n    return undefined;\n  }\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    throw new Error(platform + ' text is required');\n  }\n  if ([...value].length > limit) {\n    throw new Error(platform + ' text exceeds ' + limit + ' characters');\n  }\n  return value;\n}\n\nconst blueskyText = parseText('bluesky', 300);\nenabled.bluesky = blueskyText === undefined\n  ? { enabled: false }\n  : { enabled: true, text: blueskyText };\n\nconst linkedinText = parseText('linkedin', 3000);\nif (linkedinText === undefined) {\n  enabled.linkedin = { enabled: false };\n} else {\n  const authorUrn = typeof platforms.linkedin?.authorUrn === 'string'\n    ? platforms.linkedin.authorUrn.trim()\n    : '';\n  if (!/^urn:li:(person|organization):/.test(authorUrn)) {\n    throw new Error('LinkedIn authorUrn must be a person or organization URN');\n  }\n  enabled.linkedin = {\n    enabled: true,\n    text: linkedinText,\n    authorUrn\n  };\n}\n\nif (!enabled.bluesky.enabled && !enabled.linkedin.enabled) {\n  throw new Error('No supported Social Deck platforms were enabled');\n}\n\nreturn [{ json: {\n  route: 'publish',\n  source: body.source ?? {},\n  requestedAt: body.requestedAt ?? null,\n  platforms: enabled,\n  results: []\n} }];"
      },
