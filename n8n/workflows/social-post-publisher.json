    {
      "parameters": {
        "jsCode": "const previous = $('If Bluesky enabled').first().json;\nconst session = $('Create Bluesky session').first().json;\nconst post = $json;\nconst rkey = typeof post.uri === 'string' ? post.uri.split('/').pop() : undefined;\nconst result = {\n  ok: true,\n  platform: 'bluesky',\n  uri: post.uri,\n  cid: post.cid,\n  url: session.handle && rkey ? 'https://bsky.app/profile/' + session.handle + '/post/' + rkey : undefined\n};\nreturn [{ json: { ...previous, results: [...(previous.results ?? []), result] } }];"
