      "parameters": {
        "jsCode": "const previous = $('If X enabled').first().json;\nconst response = $json;\nconst tweet = response.data ?? response;\nconst username = previous.platforms.x.username;\nconst id = tweet.id;\nconst result = {\n  ok: true,\n  platform: 'x',\n  id,\n  text: tweet.text,\n  url: id ? (username ? 'https://x.com/' + username + '/status/' + id : 'https://x.com/i/web/status/' + id) : undefined\n};\nreturn [{ json: { ...previous, results: [...(previous.results ?? []), result] } }];"
