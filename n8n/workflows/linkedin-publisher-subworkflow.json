    {
      "parameters": {
        "jsCode": "const linkedin = $json.platforms?.linkedin ?? $json.linkedin ?? {};\nconst text = linkedin.text;\n\nif (typeof text !== 'string' || text.trim().length === 0) {\n  throw new Error('LinkedIn text is required');\n}\nif ([...text].length > 3000) {\n  throw new Error('LinkedIn text exceeds 3000 characters');\n}\n\nreturn [{ json: {\n  ...$json,\n  linkedin: {\n    text\n  }\n} }];"
      },
      "id": "9e969bba-1379-408b-bbb7-7dd2ddc126e2",
