        "jsCode": "const response = $json;\nconst id = response.urn ?? response.id;\n\nif (typeof id !== 'string' || id.length === 0) {\n  throw new Error('LinkedIn did not return a post ID');\n}\n\nreturn [{ json: {\n  ok: true,\n  platform: 'linkedin',\n  id\n} }];"
      },
